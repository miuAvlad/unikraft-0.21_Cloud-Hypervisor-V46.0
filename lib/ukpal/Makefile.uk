$(eval $(call addlib_s,libukpal,$(CONFIG_LIBUKPAL)))

ASINCLUDES-$(CONFIG_LIBUKPAL)  += -I$(LIBUKPAL_BASE)/include
CINCLUDES-$(CONFIG_LIBUKPAL)   += -I$(LIBUKPAL_BASE)/include
CXXINCLUDES-$(CONFIG_LIBUKPAL) += -I$(LIBUKPAL_BASE)/include

ASINCLUDES-$(CONFIG_LIBUKPAL)  += -I$(LIBUKPAL_BASE)/arch/$(CONFIG_UK_ARCH)/include
CINCLUDES-$(CONFIG_LIBUKPAL)   += -I$(LIBUKPAL_BASE)/arch/$(CONFIG_UK_ARCH)/include
CXXINCLUDES-$(CONFIG_LIBUKPAL) += -I$(LIBUKPAL_BASE)/arch/$(CONFIG_UK_ARCH)/include
