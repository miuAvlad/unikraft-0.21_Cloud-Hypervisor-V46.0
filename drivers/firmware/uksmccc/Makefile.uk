$(eval $(call addlib_s,libuksmccc,$(CONFIG_LIBUKSMCCC)))

ASINCLUDES-$(CONFIG_LIBUKSMCCC)   += -I$(LIBUKSMCCC_BASE)/include
CINCLUDES-$(CONFIG_LIBUKSMCCC)   += -I$(LIBUKSMCCC_BASE)/include
CXXINCLUDES-$(CONFIG_LIBUKSMCCC) += -I$(LIBUKSMCCC_BASE)/include

LIBUKSMCCC_SRCS-y += $(LIBUKSMCCC_BASE)/smccc.c
LIBUKSMCCC_SRCS-y += $(LIBUKSMCCC_BASE)/smccc_invoke.S
