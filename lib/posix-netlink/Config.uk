config LIBPOSIX_NETLINK
	bool "posix-netlink: Abstraction for netlink protocols"
	select LIBPOSIX_SOCKET
	help
	  This microlibrary allows other microlibraries to register a
	  netlink protocol family, such as NETLINK_ROUTE, for their netlink
	  module implementation. This library regsiters the POSIX socket API
	  unikernel-wide and acts appropriately on a given file descriptor.
