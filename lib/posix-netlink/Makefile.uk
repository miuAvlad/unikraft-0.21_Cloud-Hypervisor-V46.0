$(eval $(call addlib_s,libposix_netlink,$(CONFIG_LIBPOSIX_NETLINK)))

LIBPOSIX_NETLINK_COMMON_INCLUDES-y += -I$(LIBPOSIX_NETLINK_BASE)/include
CINCLUDES-$(CONFIG_LIBPOSIX_NETLINK) += $(LIBPOSIX_NETLINK_COMMON_INCLUDES-y)
CXXINCLUDES-$(CONFIG_LIBPOSIX_NETLINK) += $(LIBPOSIX_NETLINK_COMMON_INCLUDES-y)
