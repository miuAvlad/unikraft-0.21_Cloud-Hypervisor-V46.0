$(eval $(call addlib_s,libukacpi,$(CONFIG_LIBUKACPI)))

ASINCLUDES-$(CONFIG_LIBUKACPI) += -I$(LIBUKACPI_BASE)/include
CINCLUDES-$(CONFIG_LIBUKACPI) += -I$(LIBUKACPI_BASE)/include
CXXINCLUDES-$(CONFIG_LIBUKACPI) += -I$(LIBUKACPI_BASE)/include

LIBUKACPI_CINCLUDES-y += -I$(UK_PLAT_COMMON_BASE)/include

LIBUKACPI_SRCS-$(CONFIG_LIBUKACPI) += $(LIBUKACPI_BASE)/acpi.c
